# ── WhatsApp Dashboard — Environment Config ───────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Meta / WhatsApp Cloud API ─────────────────────────────────────────────────
# Get these from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here

# ── Webhook Verification ──────────────────────────────────────────────────────
# You choose this value. Enter the SAME string in the Meta Developer Console
# under Webhooks → Verify Token when setting up your webhook URL.
WEBHOOK_VERIFY_TOKEN=my_super_secret_token_123

# ── Meta Catalog Integration ──────────────────────────────────────────────────
# Required for Catalog Integration feature
# Get these from: https://developers.facebook.com → Your App → Settings → Basic
META_APP_ID=your_meta_app_id_here
META_CONFIG_ID=your_embedded_signup_config_id_here
META_BUSINESS_ID=your_business_id_here
META_WABA_ID=your_whatsapp_business_account_id_here
META_REDIRECT_URI=http://localhost:8000/catalog.html

# ── AI Providers ──────────────────────────────────────────────────────────────
# Set the API key for each provider you want to use.
# At least one provider must be configured to enable AI agent mode.

# OpenAI / ChatGPT — Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama (Local LLM) — Install from: https://ollama.ai
# No API key needed. Just ensure Ollama is running locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
