rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow the administrative dashboard (authenticated) to manage everything
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow public read for specific public data if needed (e.g. business info)
    // For now, keeping it locked to authenticated users/server SDK
  }
}
